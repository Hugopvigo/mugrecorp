---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { type Lang, getLangFromUrl, getAlternateLangUrl, getLocalizedPath } from '../i18n/utils';

interface Props {
  lang?: Lang;
  title?: string;
  description?: string;
}

const { lang: propLang, title, description } = Astro.props;
const lang = propLang || getLangFromUrl(Astro.url);
const pageTitle = title || 'MugreCorp';
const pageDescription = description || 'Computación distribuida, ecológica y sin data centers.';
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const base = import.meta.env.BASE_URL;
const alternateLangs = getAlternateLangUrl(Astro.url);

function buildAlternateHref(href: string): string {
  return new URL(base + href.replace(/^\//, ''), Astro.site).href;
}

const xDefaultHref = buildAlternateHref(alternateLangs.find(a => a.lang === 'es')!.href);
const fontUrl = 'https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap';
---

<!doctype html>
<html lang={lang} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:locale" content={lang === 'es' ? 'es_ES' : 'en_US'} />
    <meta property="og:locale:alternate" content={lang === 'es' ? 'en_US' : 'es_ES'} />
    <meta property="og:site_name" content="MugreCorp" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/x-icon" href={base + 'favicon.ico'} />
    <link rel="canonical" href={canonicalURL.href} />
    {alternateLangs.map(({ lang: l, href }) => (
      <link rel="alternate" hreflang={l === 'es' ? 'es' : 'en'} href={buildAlternateHref(href)} />
    ))}
    <link rel="alternate" hreflang="x-default" href={xDefaultHref} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href={fontUrl} rel="stylesheet" />
    <title>{pageTitle}</title>
  </head>
  <body class="bg-black text-white font-sans antialiased">
    <Navbar lang={lang} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
