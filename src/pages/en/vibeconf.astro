---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ScrollReveal from '../../components/ScrollReveal';
import { t } from '../../i18n/utils';

const lang = 'en' as const;
---

<BaseLayout lang={lang} title={t('vibeconf.hero_title', lang) + ' — MugreCorp'}>
  <section class="relative min-h-[70vh] flex items-center overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/vibeconf.webp" alt="" class="w-full h-full object-cover opacity-25" />
      <div class="absolute inset-0 bg-gradient-to-b from-black via-black/70 to-black"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-32 pb-20 text-center">
      <ScrollReveal client:load>
        <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold mb-6">{t('vibeconf.hero_title', lang)}</h1>
      </ScrollReveal>
      <ScrollReveal client:load delay={100}>
        <p class="text-xl sm:text-2xl text-zinc-400 max-w-2xl mx-auto mb-10">{t('vibeconf.hero_subtitle', lang)}</p>
      </ScrollReveal>
      <ScrollReveal client:load delay={200}>
        <a href="#register" class="inline-flex items-center justify-center bg-emerald-500 hover:bg-emerald-600 text-black font-semibold px-8 py-4 rounded-lg transition-colors">
          {t('vibeconf.cta', lang)}
        </a>
      </ScrollReveal>
    </div>
  </section>

  <section class="py-24 sm:py-32 bg-dark-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <ScrollReveal client:load>
          <div>
            <p class="text-zinc-400 text-lg leading-relaxed mb-8">{t('vibeconf.desc', lang)}</p>
            <div class="flex flex-col gap-4">
              <div class="glass rounded-xl px-6 py-4 flex items-center gap-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
                <span class="text-zinc-300">{t('vibeconf.date', lang)}</span>
              </div>
              <div class="glass rounded-xl px-6 py-4 flex items-center gap-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                <span class="text-zinc-300">{t('vibeconf.location', lang)}</span>
              </div>
            </div>
          </div>
        </ScrollReveal>
        <ScrollReveal client:load delay={150}>
          <div class="glass rounded-2xl overflow-hidden">
            <img src="/images/vibeconf.webp" alt="VibeConf" class="w-full opacity-80" />
          </div>
        </ScrollReveal>
      </div>
    </div>
  </section>

  <section id="register" class="py-24 sm:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <ScrollReveal client:load>
        <a href="/en/contacto" class="inline-flex items-center justify-center bg-emerald-500 hover:bg-emerald-600 text-black font-semibold px-8 py-4 rounded-lg transition-colors text-lg">
          {t('vibeconf.cta', lang)}
        </a>
      </ScrollReveal>
    </div>
  </section>
</BaseLayout>