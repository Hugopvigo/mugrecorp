---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/utils';

const lang = 'en' as const;
---

<BaseLayout lang={lang} title={t('legal.privacy_title', lang) + ' — MugreCorp'}>
  <section class="pt-32 pb-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-6 mb-12">
        <img src="/images/logo-eu-inc.png" alt={t('footer.eu_inc', lang)} class="h-16 opacity-60" />
        <div>
          <h1 class="text-3xl sm:text-4xl font-bold">{t('legal.privacy_title', lang)}</h1>
        </div>
      </div>
      <div class="glass rounded-2xl p-8 sm:p-12">
        <p class="text-zinc-400 leading-relaxed text-lg">{t('legal.privacy_content', lang)}</p>
      </div>
    </div>
  </section>
</BaseLayout>