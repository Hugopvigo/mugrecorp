---
import BaseLayout from '../layouts/BaseLayout.astro';
import ScrollReveal from '../components/ScrollReveal';
import { t, getLocalizedPath, assetPath } from '../i18n/utils';

const lang = 'es' as const;
---

<BaseLayout lang={lang} title={t('mugrenetes.hero_title', lang) + ' — MugreCorp'}>
  <section class="relative min-h-[60vh] flex items-center overflow-hidden">
    <div class="absolute inset-0">
      <img src={assetPath('/images/mugrenetes.webp')} alt="" class="w-full h-full object-cover opacity-15" />
      <div class="absolute inset-0 bg-gradient-to-b from-black via-black/80 to-black"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-32 pb-20">
      <ScrollReveal client:load>
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold mb-6">{t('mugrenetes.hero_title', lang)}</h1>
      </ScrollReveal>
      <ScrollReveal client:load delay={100}>
        <p class="text-xl sm:text-2xl text-zinc-400 max-w-2xl mb-10">{t('mugrenetes.hero_subtitle', lang)}</p>
      </ScrollReveal>
      <ScrollReveal client:load delay={200}>
        <a href="#what" class="inline-flex items-center justify-center bg-emerald-500 hover:bg-emerald-600 text-black font-semibold px-8 py-4 rounded-lg transition-colors">
          {t('mugrenetes.cta', lang)}
        </a>
      </ScrollReveal>
    </div>
  </section>

  <section id="what" class="py-24 sm:py-32 bg-dark-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <ScrollReveal client:load>
          <div>
            <h2 class="text-3xl sm:text-4xl font-bold mb-6">{t('mugrenetes.what_title', lang)}</h2>
            <p class="text-zinc-400 text-lg leading-relaxed">{t('mugrenetes.what_desc', lang)}</p>
          </div>
        </ScrollReveal>
        <ScrollReveal client:load delay={150}>
          <div class="glass rounded-2xl overflow-hidden">
            <img src={assetPath('/images/mugrenetes2.webp')} alt="Mugrenetes" class="w-full opacity-80" />
          </div>
        </ScrollReveal>
      </div>
    </div>
  </section>

  <section class="py-24 sm:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <ScrollReveal client:load>
        <div class="glass rounded-2xl p-8 sm:p-12 text-center max-w-3xl mx-auto">
          <h2 class="text-3xl sm:text-4xl font-bold mb-6">{t('mugrenetes.resilience_title', lang)}</h2>
          <p class="text-zinc-400 text-lg leading-relaxed">{t('mugrenetes.resilience_desc', lang)}</p>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <section class="py-24 sm:py-32 bg-dark-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <ScrollReveal client:load>
        <div class="glass rounded-2xl p-8 sm:p-12 text-center max-w-3xl mx-auto">
          <h2 class="text-3xl sm:text-4xl font-bold mb-6">{t('mugrenetes.gamification_title', lang)}</h2>
          <p class="text-zinc-400 text-lg leading-relaxed">{t('mugrenetes.gamification_desc', lang)}</p>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <section class="py-24 sm:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <ScrollReveal client:load>
        <a href={getLocalizedPath('/contacto', lang)} class="inline-flex items-center justify-center bg-emerald-500 hover:bg-emerald-600 text-black font-semibold px-8 py-4 rounded-lg transition-colors text-lg">
          {t('mugrenetes.cta', lang)}
        </a>
      </ScrollReveal>
    </div>
  </section>
</BaseLayout>
